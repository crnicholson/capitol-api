# Server
PORT=3000

# Date range to fetch (inclusive)
YEARS_START=2025
YEARS_END=2026

# Cache refresh interval in hours. 0 = never refresh automatically (still fetches on startup if no cache).
CACHE_REFRESH_HOURS=0

# Delay in ms between PDF download requests (be polite to the government server)
FETCH_DELAY_MS=500

# Max concurrent Yahoo Finance price lookups
PRICE_CONCURRENCY=3
